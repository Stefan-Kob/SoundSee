@model SoundSee.ViewModels.UserViewModel
@{ 
    string emailVal = "";
    string usernameVal = "";
    string passwordVal = "";

    if (Model.User.Email != null)
    {
        emailVal = "Model.User.Email";
        usernameVal = "Model.User.Username";
        passwordVal = "Model.User.Password";
    }
}

<div>
    <label for="Email" class="form-label mt-3">Email address</label>
    <input type="Email" name="Email" asp-for="@Model.User.Email" class="form-control" id="exampleInputEmail1" aria-describedby="emailHelp" placeholder="johndoe@email.com" value="@emailVal">
</div>

<div>
    *
    <label class="col-form-label mt-2" for="Username">Username</label>
    <input type="text" name="Username" asp-for="@Model.User.Username" class="form-control" placeholder="John Doe's Super Account" id="Username" value="@usernameVal">
</div>

<div>
    <label for="Password" class="form-label mt-2">Password</label>
    <input type="password" name="Password" asp-for="@Model.User.Password" class="form-control" id="exampleInputPassword1" placeholder="Password" autocomplete="off" value="@passwordVal">
</div>

<div class="form-check form-switch mt-3">
    <input class="form-check-input" type="checkbox" name="SignUpForNewsletters" asp-for="@Model.User.SignUpForNewsletters" id="SignUpForNewsletters">
    <label class="form-check-label" for="SignUpForNewsletters">Sign up for marketing newsletters, and any great offers we have!</label>
</div>
